{
  "graph_id": "anime_machine_lamarre_v1",
  "graph_name": "动画机器 - 托马斯·拉马尔核心概念图谱",
  "source": "Lamarre, Thomas. The Anime Machine: A Media Theory of Animation. University of Minnesota Press, 2009.",
  "framework": "N9R20-RHIZOME",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "ANIME_MACHINE",
      "term": "动画机器 (Anime Machine)",
      "category": "root_concept",
      "definition": "动画制作的技术装置与其产生的感知模式之间的耦合配置",
      "provenance": "Introduction, pp. xiii-xxvi",
      "links_to": ["MULTIPLANAR_IMAGE", "LIMITED_ANIMATION", "ANIMETIC_INTERVAL", "CINEMATISM", "ANIMETISM"]
    },
    {
      "id": "MULTIPLANAR_IMAGE",
      "term": "多平面图像 (Multiplanar Image)",
      "category": "core_concept",
      "definition": "通过多层分离平面的垂直堆叠合成单一图像的动画技术产物，层间保持离散性而非融合为连续深空间",
      "provenance": "Chapter 1, pp. 1-44",
      "links_to": ["ANIME_MACHINE", "LIMITED_ANIMATION", "SLIDING", "FIELD_DISTRIBUTION", "COMPOSITING_GAP"]
    },
    {
      "id": "LIMITED_ANIMATION",
      "term": "有限动画 (Limited Animation)",
      "category": "core_concept",
      "definition": "每秒8-12帧、大量静止图像复用、局部运动为主的动画技术；拉马尔论证其为积极技术选择而非经济限制的缺陷",
      "provenance": "Chapter 2, pp. 45-63",
      "links_to": ["ANIMETIC_INTERVAL", "FULL_ANIMATION", "ANIMETISM", "SLIDING"]
    },
    {
      "id": "ANIMETIC_INTERVAL",
      "term": "动画间隔 (Animetic Interval)",
      "category": "core_concept",
      "definition": "帧之间、层之间、感知之间的'之间性'；动画生命发生的场所，观者感知填充的工作空间",
      "provenance": "Chapter 3, pp. 64-85",
      "links_to": ["LIMITED_ANIMATION", "MULTIPLANAR_IMAGE", "FIELD_DISTRIBUTION"]
    },
    {
      "id": "CINEMATISM",
      "term": "电影主义 (Cinematism)",
      "category": "core_concept",
      "definition": "动画中朝向或远离摄像机的纵深运动倾向，单点透视结构，导向统一的沉浸式主体",
      "provenance": "Chapter 4, pp. 86-116",
      "links_to": ["ANIMETISM", "FULL_ANIMATION", "TENSION_FIELD"]
    },
    {
      "id": "ANIMETISM",
      "term": "动画主义 (Animetism)",
      "category": "core_concept",
      "definition": "动画中横向穿越图像平面的运动倾向，多层平面结构，导向分散的分布主体",
      "provenance": "Chapter 4, pp. 86-116",
      "links_to": ["CINEMATISM", "SLIDING", "LIMITED_ANIMATION", "FIELD_DISTRIBUTION"]
    },
    {
      "id": "SLIDING",
      "term": "滑动 (Sliding)",
      "category": "core_concept",
      "definition": "角色在静止背景平面上横向移动而不缝合平面差异的技术，动画主义最纯粹的技术表现",
      "provenance": "Chapter 5, pp. 117-144",
      "links_to": ["ANIMETISM", "MULTIPLANAR_IMAGE", "COMPOSITING_GAP"]
    },
    {
      "id": "FIELD_DISTRIBUTION",
      "term": "场的分布 (Distribution of the Field)",
      "category": "core_concept",
      "definition": "多平面图像结构中注意力与可感性在各层之间的分配，非人类中心的视觉体制",
      "provenance": "Chapter 6, pp. 145-186",
      "links_to": ["MULTIPLANAR_IMAGE", "ANIMETISM", "ANIMETIC_INTERVAL"]
    },
    {
      "id": "FULL_ANIMATION",
      "term": "全动画 (Full Animation)",
      "category": "contrast_concept",
      "definition": "每秒24帧逐帧绘制、运动平滑连续的迪士尼式动画；电影主义的典型技术载体",
      "provenance": "Chapter 2 (contrast), pp. 45-63",
      "links_to": ["LIMITED_ANIMATION", "CINEMATISM"]
    },
    {
      "id": "COMPOSITING_GAP",
      "term": "合成间隙 (Compositing Gap)",
      "category": "sub_concept",
      "definition": "多平面图像中层与层之间的空间间隙；非缝合性连接，差异的可见痕迹",
      "provenance": "Derived from Chapters 1 & 3",
      "links_to": ["MULTIPLANAR_IMAGE", "SLIDING", "ANIMETIC_INTERVAL"]
    },
    {
      "id": "TENSION_FIELD",
      "term": "张力场 (Tension Field)",
      "category": "meta_concept",
      "definition": "电影主义与动画主义并非二元对立而是在每部作品中以不同比例构成的结构性张力空间",
      "provenance": "Chapter 4, pp. 86-116",
      "links_to": ["CINEMATISM", "ANIMETISM", "ANIME_MACHINE"]
    },
    {
      "id": "ANIMATION_STAND",
      "term": "动画摄影台 (Animation Stand)",
      "category": "technical_term",
      "definition": "赛璐珞动画时代的多平面垂直摄影设备；动画机器的技术硬件核心",
      "provenance": "Introduction & Chapter 1",
      "links_to": ["ANIME_MACHINE", "MULTIPLANAR_IMAGE"]
    }
  ],
